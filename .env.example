# ===== BluePrint - Engineering Consultancy ERP =====
# Copy this file to .env (on Windows: copy .env.example .env)

# Database (SQLite - for development)
DATABASE_URL="file:./db/custom.db"

# JWT Secret (REQUIRED - Generate with: openssl rand -base64 48)
# DO NOT use the example value in production!
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-characters-long

# NextAuth Configuration
NEXTAUTH_SECRET="change-me-to-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo Mode (set to "false" in production)
DEMO_MODE=true
