# ==============================================================================
# BluePrint Engineering Consultancy ERP - Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values.
# On Windows: copy .env.example .env
# On macOS/Linux: cp .env.example .env
#
# SECURITY WARNING:
#   - Never commit .env files to version control
#   - Generate strong secrets for production (see commands below)
#   - Replace ALL placeholder values before deploying
# ==============================================================================

# ==============================================================================
# APPLICATION
# ==============================================================================

# Application environment: development | production | test
NODE_ENV=development

# Application port (default: 3000)
PORT=3000

# Public-facing URL of the application
# Required in production; must use HTTPS in production
# Example: https://app.blueprint.ae
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application version (used by Sentry for release tracking)
# NEXT_PUBLIC_APP_VERSION=1.0.0

# Demo mode toggle — when "true", the app runs with pre-seeded demo credentials
# and restricted write operations. Set to "false" in production.
DEMO_MODE=true

# ==============================================================================
# DATABASE
# ==============================================================================

# Database connection URL
# SQLite (development): file:./db/custom.db
# PostgreSQL (production): postgresql://user:password@host:5432/blueprint?schema=public
DATABASE_URL="file:./db/custom.db"

# ==============================================================================
# AUTHENTICATION - JWT
# ==============================================================================

# JWT secret for signing and verifying tokens (REQUIRED in production)
# Must be at least 32 characters. Generate with: openssl rand -base64 48
# DO NOT use the example value in production!
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-characters-long

# JWT access token expiry duration (default: 2h)
# Examples: 15m, 1h, 2h, 4h
# JWT_EXPIRES_IN=2h

# JWT refresh token expiry duration (default: 7d)
# Examples: 7d, 14d, 30d
# JWT_REFRESH_EXPIRES_IN=7d

# ==============================================================================
# AUTHENTICATION - NextAuth
# ==============================================================================

# NextAuth.js secret for session encryption (REQUIRED in production)
# Generate with: openssl rand -base64 48
NEXTAUTH_SECRET=change-me-to-a-secure-random-string

# NextAuth.js URL — the canonical URL of your app
# Used for constructing callback URLs in auth flows
NEXTAUTH_URL=http://localhost:3000

# ==============================================================================
# ENCRYPTION
# ==============================================================================

# AES-256-GCM encryption key for sensitive field-level encryption
# Must be exactly 64 hex characters (32 bytes) in production
# Generate with: openssl rand -hex 32
# A development default is used if not set, but this MUST be set in production
# ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ==============================================================================
# CORS / ALLOWED ORIGINS
# ==============================================================================

# Comma-separated list of allowed CORS origins for API requests
# In development, localhost origins are automatically allowed
# In production, this should be set to your domain(s)
# Both CORS_ORIGINS and ALLOWED_ORIGINS are checked (either works)
# Example: https://app.blueprint.ae,https://admin.blueprint.ae
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# ALLOWED_ORIGINS=http://localhost:3000

# ==============================================================================
# RATE LIMITING
# ==============================================================================

# General API rate limit — max requests per window (default: 100)
# RATE_LIMIT_MAX=100

# General API rate limit — window duration in milliseconds (default: 60000)
# RATE_LIMIT_WINDOW_MS=60000

# Auth endpoint rate limit — max requests per window (default: 10)
# RATE_LIMIT_AUTH_MAX=10

# Auth endpoint rate limit — window duration in milliseconds (default: 60000)
# RATE_LIMIT_AUTH_WINDOW_MS=60000

# Public endpoint rate limit — max requests per window (default: 200)
# RATE_LIMIT_PUBLIC_MAX=200

# Public endpoint rate limit — window duration in milliseconds (default: 60000)
# RATE_LIMIT_PUBLIC_WINDOW_MS=60000

# ==============================================================================
# STRIPE (PAYMENTS)
# ==============================================================================

# Stripe secret key — used for server-side API calls
# Test mode: sk_test_... | Live mode: sk_live_...
# If not set, Stripe features are gracefully disabled
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe webhook signing secret — used to verify webhook event signatures
# Find in Stripe Dashboard > Developers > Webhooks
# STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ==============================================================================
# EMAIL / SMTP
# ==============================================================================

# SMTP server hostname (e.g., smtp.sendgrid.net, smtp.gmail.com)
# If not set, emails are logged to console in development mode
# SMTP_HOST=smtp.sendgrid.net

# SMTP server port (default: 587 for TLS, 465 for SSL)
# SMTP_PORT=587

# SMTP authentication username
# SMTP_USER=apikey

# SMTP authentication password
# SMTP_PASS=your_smtp_password_here

# Sender email address for outgoing emails
# Falls back to SMTP_FROM, then to noreply@blueprint.ae
# EMAIL_FROM=noreply@blueprint.ae
# SMTP_FROM=noreply@blueprint.ae

# SendGrid API key (alternative to SMTP — checked in health dashboard)
# SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# ==============================================================================
# REDIS / CACHE
# ==============================================================================

# Redis connection URL (default: redis://localhost:6379)
# If not set, caching falls back to in-memory (no persistence across restarts)
# Example with password: redis://:password@localhost:6379
# REDIS_URL=redis://localhost:6379

# Redis password (checked alongside REDIS_URL in environment validation)
# REDIS_PASSWORD=

# Redis database number (default: 0)
# REDIS_DB=0

# Key prefix for all Redis cache entries (default: blueprint:)
# REDIS_PREFIX=blueprint:

# Default TTL for cache entries in seconds (used by cache-manager)
# CACHE_DEFAULT_TTL=3600

# Custom key prefix for cache-manager (separate from Redis prefix)
# CACHE_KEY_PREFIX=

# ==============================================================================
# MONITORING / SENTRY
# ==============================================================================

# Sentry DSN for error monitoring (client-side, uses NEXT_PUBLIC_ prefix)
# This is exposed to the browser bundle intentionally for client-side tracing
# If not set, Sentry is disabled and errors are only logged to console
# NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_key@o0.ingest.sentry.io/0

# Enable Sentry in development mode (default: disabled)
# Set to "true" to test Sentry integration locally
# SENTRY_ENABLE_DEV=

# ==============================================================================
# WEBSOCKET
# ==============================================================================

# WebSocket server URL for real-time notifications and live updates
# Used by the client-side WebSocket context
# NEXT_PUBLIC_WEBSOCKET_URL=ws://localhost:3001

# ==============================================================================
# BACKUP
# ==============================================================================

# Local directory for database backups (default: ./backups)
# BACKUP_DIR=./backups

# Number of days to retain backups (default: 30)
# BACKUP_RETENTION_DAYS=30

# Enable backup compression (default: true; set to "false" to disable)
# BACKUP_COMPRESSION=true

# Enable backup encryption (default: false; set to "true" to enable)
# BACKUP_ENCRYPTION=false

# Encryption key for backups (required if BACKUP_ENCRYPTION=true)
# BACKUP_ENCRYPTION_KEY=

# Enable S3/cloud backup storage (default: false; set to "true" to enable)
# BACKUP_S3_ENABLED=false

# S3 bucket name for cloud backups
# BACKUP_S3_BUCKET=

# S3 region for cloud backups
# BACKUP_S3_REGION=

# AWS credentials for S3 backup storage
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ==============================================================================
# AI SERVICES
# ==============================================================================

# The AI chat endpoint uses the z-ai-web-dev-sdk which auto-configures.
# No additional API keys are required for the built-in AI assistant.
# If you wish to use OpenAI or other providers in the future, add keys below:
# OPENAI_API_KEY=sk-your_openai_api_key_here

# ==============================================================================
# HOSTING / DEPLOYMENT
# ==============================================================================

# Server hostname (used in health check endpoint, falls back to HOST)
# HOSTNAME=localhost
# HOST=localhost
