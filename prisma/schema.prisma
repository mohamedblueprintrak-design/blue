  order             Int      @default(0)
  assignedRole      String   @default("")
  isRequired        Boolean  @default(true)
  requiresApproval  Boolean  @default(false)
  autoComplete      Boolean  @default(false)
  onCompleteAction  String   @default("next_step")
  daysToComplete    Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  stage             WorkflowTemplateStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([stageId, order])
}

model ProjectWorkflow {
  id              String   @id @default(cuid())
  projectId       String   @unique
  templateId      String?
  currentStageId  String?
  status          String   @default("active")
  progress        Float    @default(0)
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project         Project  @relation(fields: [projectId], references: [id])
  template        WorkflowTemplate? @relation(fields: [templateId], references: [id])
  stages          WorkflowStage[]
}

model WorkflowStage {
  id              String   @id @default(cuid())
  workflowId      String
  templateStageId String?
  name            String   @default("")
  nameEn          String   @default("")
  order           Int      @default(0)
  status          String   @default("pending")
  startDate       DateTime?
  dueDate         DateTime?
  completedDate   DateTime?
  assigneeId      String?
  notes           String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workflow        ProjectWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  steps           WorkflowStep[]

  @@index([workflowId, order])
}

model WorkflowStep {
  id              String   @id @default(cuid())
  stageId         String
  templateStepId  String?
  name            String   @default("")
  nameEn          String   @default("")
  order           Int      @default(0)
  status          String   @default("locked")
  assigneeId      String?
  assignedRole    String   @default("")
  startDate       DateTime?
  dueDate         DateTime?
  completedDate   DateTime?
  action          String   @default("")
  notes           String   @default("")
  returnReason     String   @default("")
  severity        String   @default("normal")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  stage           WorkflowStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([stageId, order])
}

// ==================== SAAS MULTI-TENANT MODELS ====================

// Organization (Tenant)
model Organization {
  id               String    @id @default(cuid())
  name             String
  slug             String    @unique
  logo             String?
  description      String?
  website          String?
  phone            String?
  email            String?
  address          String?
  taxNumber        String?
  currency         String    @default("AED")
  timezone         String    @default("Asia/Dubai")
  locale           String    @default("ar")
  isActive         Boolean   @default(true)
  planId           String?   // Current plan ID
  deletedAt        DateTime? // Soft delete
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  plan             Plan?     @relation(fields: [planId], references: [id])
  users            User[]
  subscriptions    Subscription[]

  @@index([deletedAt])
}

// Subscription Plans
model Plan {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  nameAr          String?   // Arabic name
  description     String?
  descriptionAr   String?   // Arabic description
  price           Float
  currency        String    @default("AED")
  interval        SubscriptionInterval @default(MONTH)
  stripeProductId String?
  stripePriceId   String?
  features        String    @default("{}") // JSON string for features
  limits          String    @default("{}") // JSON string for limits
  isActive        Boolean   @default(true)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())

  subscriptions   Subscription[]
  organizations   Organization[]
}

// Organization Subscriptions
model Subscription {
  id                  String    @id @default(cuid())
  organizationId      String
  planId              String
  status              SubscriptionStatus @default(ACTIVE)
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  cancelAtPeriodEnd   Boolean   @default(false)
  stripeSubscriptionId String?
  stripeCustomerId    String?
  stripePaymentIntentId String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan               Plan        @relation(fields: [planId], references: [id])
  subscriptionPayments SubscriptionPayment[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([planId])
}

// Subscription Payments (SaaS)
model SubscriptionPayment {
  id                  String    @id @default(cuid())
  subscriptionId      String
  amount              Float
  currency            String    @default("AED")
  status              PaymentStatus @default(PENDING)
  stripePaymentIntentId String?
  stripeChargeId      String?
  stripeInvoiceId     String?
  receiptUrl          String?
  description         String?
  metadata            String?   // JSON string
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  subscription        Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

// Email Verification Token
model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  userId    String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

// Password Reset Token
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  userId    String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

// Two-Factor Authentication Secret
model TwoFactorSecret {
  id           String   @id @default(cuid())
  userId       String   @unique
  secret       String   // Encrypted TOTP secret
  backupCodes  String   // JSON string for backup codes
  isEnabled    Boolean  @default(false)
  verifiedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

// Two-Factor Challenge
model TwoFactorChallenge {
  id        String   @id @default(cuid())
  userId    String
  code      String
  type      TwoFactorChallengeType @default(TOTP)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([code])
  @@index([expiresAt])
}

// SLA Breach Tracking
model SLABreach {
  id              String    @id @default(cuid())
  taskId          String
  projectId       String?
  status          SLABreachStatus @default(WARNING)
  daysElapsed     Int       @default(0)       // Days since SLA start
  slaDays         Int       @default(0)       // Expected SLA days
  breachDays      Int       @default(0)       // Days over SLA
  notifiedAt      DateTime?                   // When notification was sent
  notifiedUsers   String?                      // JSON array of user IDs notified
  resolvedAt      DateTime?                   // When breach was resolved
  resolutionNotes String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([taskId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

// User Notification Settings
model NotificationSettings {
  id                  String    @id @default(cuid())
  userId              String    @unique
  emailNotifications  Boolean   @default(true)
  pushNotifications   Boolean   @default(true)
  taskAssigned        Boolean   @default(true)
  taskDueSoon         Boolean   @default(true)
  taskOverdue         Boolean   @default(true)
  invoiceOverdue      Boolean   @default(true)
  projectUpdates      Boolean   @default(true)
  slaWarnings         Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==================== AI CHAT PERSISTENCE ====================

/// AI Chat Conversation
model AIChatConversation {
  id              String   @id @default(cuid())
  userId          String
  title           String   @default("")
  projectId       String?
  lastMessageAt   DateTime @default(now())
  messageCount    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages        AIChatMessage[]

  @@index([userId])
  @@index([projectId])
  @@index([lastMessageAt])
}

/// AI Chat Message
model AIChatMessage {
  id              String   @id @default(cuid())
  conversationId  String
  role            String   // 'user' | 'assistant' | 'system'
  content         String
  tokens          Int      @default(0)
  model           String   @default("")
  createdAt       DateTime @default(now())

  conversation    AIChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

// ==================== SECURITY AUDIT LOG ====================

/// Security Audit Log for tracking sensitive operations
model SecurityAuditLog {
  id              String   @id @default(cuid())
  userId          String?
  action          String   // login, logout, 2fa_enable, 2fa_disable, password_change, etc.
  entityType      String?
  entityId        String?
  ipAddress       String?
  userAgent       String?
  details         String?  // JSON string for additional details
  status          String   @default("success") // success, failed, blocked
  errorMessage    String?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([status])
  @@index([createdAt])
}
