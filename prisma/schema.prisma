generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct URL for migration tooling (optional, overrides url during prisma migrate)
  // directUrl = env("DIRECT_DATABASE_URL")
}

// ==================== ENUMS (SaaS Multi-tenant) ====================

/// User roles in the system
enum UserRole {
  ADMIN            // Full system access
  MANAGER          // Project management access
  PROJECT_MANAGER  // Project-level management
  ENGINEER         // Technical access
  DRAFTSMAN        // Drafting and drawing access
  ACCOUNTANT       // Financial access
  HR               // Human resources access
  SECRETARY        // Office management and documents
  VIEWER           // Read-only access
}

/// Permission types for fine-grained access control
enum Permission {
  // Project permissions
  PROJECT_CREATE
  PROJECT_READ
  PROJECT_UPDATE
  PROJECT_DELETE

  // Task permissions
  TASK_CREATE
  TASK_READ
  TASK_UPDATE
  TASK_DELETE

  // Client permissions
  CLIENT_CREATE
  CLIENT_READ
  CLIENT_UPDATE
  CLIENT_DELETE

  // Invoice permissions
  INVOICE_CREATE
  INVOICE_READ
  INVOICE_UPDATE
  INVOICE_DELETE

  // User management permissions
  USER_CREATE
  USER_READ
  USER_UPDATE
  USER_DELETE

  // Settings permissions
  SETTINGS_READ
  SETTINGS_UPDATE

  // Reports permissions
  REPORTS_READ
  REPORTS_EXPORT

  // Budget permissions
  BUDGET_MANAGE

  // Document permissions
  DOCUMENT_CREATE
  DOCUMENT_READ
  DOCUMENT_UPDATE
  DOCUMENT_DELETE
}

/// Subscription status
enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

/// Payment status for SaaS subscriptions
enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

/// Subscription interval
enum SubscriptionInterval {
  MONTH
  YEAR
}

/// Two-factor challenge type
enum TwoFactorChallengeType {
  TOTP
  BACKUP
  SMS
}

/// Task type for categorization
enum TaskType {
  STANDARD      // Regular task
  GOVERNMENTAL  // Government entity
  MANDATORY     // Mandatory for licensing
  CLIENT        // Client approval
  INTERNAL      // Internal task
}

/// SLA breach status for monitoring
enum SLABreachStatus {
  WARNING       // Warning before SLA expires
  BREACHED      // SLA exceeded
  CRITICAL      // Critical breach
  RESOLVED      // Resolved
}

/// Government approval status
enum GovernmentApprovalStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

/// Utility connection status
enum UtilityConnectionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// ==================== USERS & AUTH ====================

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String    @default("hashed_password")
  name            String    @default("")
  phone           String    @default("")
  avatar          String    @default("")
  role            String    @default("viewer") // admin, manager, project_manager, engineer, draftsman, accountant, hr, secretary, viewer
  department      String    @default("")
  position        String    @default("")
  isActive        Boolean   @default(true)
  lastLogin       DateTime?
  organizationId  String?   // SaaS multi-tenant organization
  deletedAt       DateTime? // Soft delete
  // Email verification
  emailVerified   DateTime?
  verifyToken     String?
  verifyTokenExpiry DateTime?
  // Password reset
  resetToken      String?
  resetTokenExpiry DateTime?
  // 2FA
  twoFactorEnabled  Boolean @default(false)
  twoFactorSecret   String?
  backupCodes       String? // JSON array of backup codes
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organization    Organization? @relation(fields: [organizationId], references: [id])
  projects        ProjectAssignment[]
  tasks           Task[]
  assignedDefects Defect[]
  activities      ActivityLog[]
  leaves          Leave[]
  createdProjects Project[] @relation("CreatedProjects")
  managedProjects Project[] @relation("ProjectManager")
  rfisFrom        RFI[]  @relation("RFIFrom")
  rfisTo          RFI[]  @relation("RFITo")
  riskActions     RiskAction[]
  meetingAttendee MeetingAttendee[]
  notifications   Notification[]
  sentTransmittals Transmittal[] @relation("TransmittalFrom")
  knowledgeArticles KnowledgeArticle[]
  employee         Employee?
  approvedPayments Payment[] @relation("PaymentApprover")
  approvedLeaves   Leave[] @relation("LeaveApprover")
  uploadedDocuments Document[] @relation("DocumentUploader")
  projectComments  ProjectComment[]
  comments         TaskComment[]
  tenders          Tender[]  @relation("TenderAssignee")
  commissions      Commission[]  @relation("CommissionUser")
  approvedCommissions Commission[]  @relation("CommissionApprover")
  referrals        Referral[]    @relation("ReferralReferrer")
  notificationSettings NotificationSettings?
  aiChatConversations AIChatConversation[]

  @@index([organizationId])
  @@index([deletedAt])
}

// ==================== COMPANY SETTINGS ====================

model CompanySettings {
  id            String   @id @default(cuid())
  name          String   @default("مكتب الاستشارات الهندسية")
  nameEn        String   @default("Engineering Consultancy Office")
  logo          String   @default("")
  email         String   @default("")
  phone         String   @default("")
  address       String   @default("")
  taxNumber     String   @default("")
  currency      String   @default("AED")
  timezone      String   @default("Asia/Dubai")
  workingDays   String   @default("sat,thu") // comma-separated
  workingHours  String   @default("08:00-17:00")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==================== PROJECTS ====================

model Project {
  id            String   @id @default(cuid())
  number        String   @unique
  name          String   @default("")
  nameEn        String   @default("")
  clientId      String
  contractorId  String?
  location      String   @default("")
  latitude      Float?
  longitude     Float?
  plotNumber    String   @default("")
  type          String   @default("villa") // villa, building, commercial, industrial
  status        String   @default("active") // active, completed, delayed, on_hold, cancelled
  progress      Float    @default(0)
  budget        Float    @default(0)
  contractValue  Float    @default(0) // Total contract value
  paymentMethod  String   @default("") // cash, cheque, transfer, installments
  paymentSchedule String  @default("") // JSON: [{milestone,amount,percentage,dueDate,status}]
  expectedDuration Int     @default(0) // Expected duration in days
  startDate     DateTime?
  endDate       DateTime?
  expectedEndDate DateTime? // Expected delivery date
  actualStartDate DateTime?
  actualEndDate   DateTime?
  contractDate    DateTime?
  description   String   @default("")
  municipalityChecklist String @default("") // JSON: [{id,label,checked,stage}]
  managerId     String?
  createdById   String
  deletedAt     DateTime? // Soft delete
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client        Client     @relation(fields: [clientId], references: [id])
  contractor    Contractor? @relation("ProjectContractor", fields: [contractorId], references: [id])
  createdBy     User     @relation("CreatedProjects", fields: [createdById], references: [id])
  manager       User?     @relation("ProjectManager", fields: [managerId], references: [id])
  assignments   ProjectAssignment[]
  tasks         Task[]
  stages        ProjectStage[]
  muniRejections MunicipalRejection[]
  govApprovals  GovApproval[]
  boqItems      BOQItem[]
  schedulePhases SchedulePhase[]
  invoices      Invoice[]
  contracts     Contract[]
  proposals     Proposal[]
  bids          Bid[]
  budgets       Budget[]
  commissions   Commission[]
  referrals     Referral[]
  siteVisits    SiteVisit[]
  defects       Defect[]
  siteDiaries   SiteDiary[]
  rfis          RFI[]
  submittals    Submittal[]
  changeOrders  ChangeOrder[]
  transmittals  Transmittal[]
  risks         Risk[]
  meetings      Meeting[]
  clientInteractions ClientInteraction[]
  documents     Document[]
  purchaseOrders PurchaseOrder[]
  inventoryItems InventoryItem[]
  payments       Payment[]
  comments       ProjectComment[]
  municipalityCorrespondence MunicipalityCorrespondence[]
  approvals      Approval[]
  notifications  Notification[]
  activityLogs   ActivityLog[]
  knowledgeArticles KnowledgeArticle[]
  designPhases   DesignPhase[]
  buildingInspections BuildingInspection[]
  supervisionChecklists SupervisionChecklist[]
  violations           Violation[]
  workflow             ProjectWorkflow?
}

// ==================== MUNICIPALITY CORRESPONDENCE ====================

model MunicipalityCorrespondence {
  id                  String   @id @default(cuid())
  projectId           String
  referenceNumber     String   @default("")
  municipality        String   @default("")
  correspondenceType  String   @default("SUBMISSION") // SUBMISSION, RESPONSE, REJECTION, APPROVAL, INQUIRY, AMENDMENT
  subject             String   @default("")
  content             String   @default("")
  submissionDate      DateTime?
  responseDate        DateTime?
  status              String   @default("PENDING") // PENDING, UNDER_REVIEW, APPROVED, REJECTED, AMENDMENT_REQUIRED
  notes               String   @default("")
  responseNotes       String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  project             Project  @relation(fields: [projectId], references: [id])
}

model ProjectComment {
  id        String   @id @default(cuid())
  content   String
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectAssignment {
  id            String   @id @default(cuid())
  projectId     String
  userId        String
  role          String   @default("team_member")
  createdAt     DateTime @default(now())

  project       Project  @relation(fields: [projectId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

// ==================== PROJECT STAGES ====================

model ProjectStage {
  id            String   @id @default(cuid())
  projectId     String
  department    String   // architectural, structural, mep_electrical, mep_plumbing, mep_water, mep_civil_defense, mep_telecom
  stageName     String   @default("")
  stageOrder    Int      @default(0)
  status        String   @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, SUBMITTED, APPROVED, REJECTED
  engineerId    String?
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       Project  @relation(fields: [projectId], references: [id])

  @@index([projectId, department])
}

model MunicipalRejection {
  id            String   @id @default(cuid())
  projectId     String
  department    String
  count         Int      @default(0)
  notes         String   @default("")
  lastRejectionDate DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project       Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, department])
}

// ==================== GOVERNMENT APPROVALS ====================

model GovApproval {
  id              String   @id @default(cuid())
  projectId       String
  authority       String   // MUN, FEWA, ETISALAT, CIVIL_DEFENSE
  status          String   @default("PENDING") // PENDING, SUBMITTED, APPROVED, REJECTED
  submissionDate  DateTime?
  approvalDate    DateTime?
  rejectionCount  Int      @default(0)
  notes           String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project         Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, authority])
}

// ==================== CLIENTS ====================

model Client {
  id              String   @id @default(cuid())
  // Basic Info
  clientType      String   @default("individual") // individual, company, government
  name            String   @default("")
  nameEn          String   @default("")
  company         String   @default("")
  companyEn       String   @default("")
  idNumber        String   @default("") // UAE ID or Commercial Registration
  nationality      String   @default("")
  idPhoto         String   @default("") // ID photo file path
  email           String   @default("")
  phone           String   @default("")
  whatsapp        String   @default("") // separate WhatsApp number
  extraPhone      String   @default("") // additional phone
  address         String   @default("")
  fullAddress     String   @default("") // JSON: {emirate,city,area,street,building,unit}
  taxNumber       String   @default("")
  creditLimit     Float    @default(0)
  paymentTerms    String   @default("")
  // Services & Project Info
  servicesWanted  String   @default("") // JSON array: ["consultation","design","license",...]
  projectType     String   @default("") // villa, apartment, commercial, industrial, residential_building, medical
  serviceType     String?  @default("") // legacy: purpose of visit
  serviceNotes    String?  // legacy: additional details
  // Land Details
  landLocation    String   @default("")
  landArea        String   @default("")
  plotNumber      String   @default("")
  planNumber      String   @default("")
  landDocuments   String   @default("") // JSON array: [{type:"survey",path:...},...]
  notes           String   @default("")
  // Referral
  referralSource  String   @default("") // social_media, referral, website, walk_in, advertisement, other
  referralDetail  String   @default("")
  // Credit & Status
  creditUsed      Float    @default(0)
  isActive        Boolean  @default(true)
  deletedAt       DateTime? // Soft delete
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projects        Project[]
  invoices        Invoice[]
  contracts       Contract[]
  proposals       Proposal[]
  interactions    ClientInteraction[]
  buildingInspections BuildingInspection[]
}

model ClientInteraction {
  id              String   @id @default(cuid())
  projectId       String
  clientId        String
  type            String   @default("meeting") // meeting, call, email
  date            DateTime
  subject         String   @default("")
  description     String   @default("")
  outcome         String   @default("")
  createdAt       DateTime @default(now())

  project         Project  @relation(fields: [projectId], references: [id])
  client          Client   @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

// ==================== TASKS ====================

model Task {
  id              String   @id @default(cuid())
  projectId       String?
  title           String   @default("")
  titleAr         String   @default("")
  description     String   @default("")
  assigneeId      String?
  priority        String   @default("normal") // normal, medium, high, urgent
  status          String   @default("todo") // todo, in_progress, review, done, cancelled
  startDate       DateTime?
  dueDate         DateTime?
  endDate         DateTime?
  progress        Float    @default(0)
  slaDays         Int?
  slaStartDate    DateTime?
  slaWarningDays  Int      @default(3)
  slaBreachedAt   DateTime?
  isGovernmental  Boolean  @default(false)
  taskType        String   @default("STANDARD") // STANDARD, GOVERNMENTAL, MANDATORY, CLIENT, INTERNAL
  dependencies    String?  // JSON array of task IDs
  color           String   @default("")
  estimatedHours  Float?
  actualHours     Float?
  isMilestone     Boolean  @default(false)
  order           Int      @default(0)
  parentId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project         Project?  @relation(fields: [projectId], references: [id])
  assignee        User?     @relation(fields: [assigneeId], references: [id])
  subtasks        Task[] @relation("TaskSubtask")
  parent          Task?     @relation("TaskSubtask", fields: [parentId], references: [id])
  comments        TaskComment[]

  @@index([projectId])
}

// ==================== TASK COMMENTS ====================

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([taskId])
}

// ==================== CONTRACTS ====================

model Contract {
  id              String   @id @default(cuid())
  number          String   @default("")
  title           String   @default("")
  clientId        String
  projectId       String
  value           Float    @default(0)
  type            String   @default("engineering_services") // engineering_services, construction, consulting, maintenance
  status          String   @default("draft") // draft, pending_signature, active, expired, completed
  signedByName    String   @default("")
  signedByTitle   String   @default("")
  signature       String   @default("")
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id])
  project         Project  @relation(fields: [projectId], references: [id])
  amendments      ContractAmendment[]
  documents       Document[]
}

model ContractAmendment {
  id              String   @id @default(cuid())
  contractId      String
  number          String   @default("")
  description     String   @default("")
  date            DateTime
  status          String   @default("pending")
  createdAt       DateTime @default(now())

  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

// ==================== INVOICES ====================

model Invoice {
  id              String   @id @default(cuid())
  number          String   @default("")
  clientId        String
  projectId       String
  issueDate       DateTime
  dueDate         DateTime
  subtotal        Float    @default(0)
  tax             Float    @default(0)
  taxRate         Float    @default(0) // Tax percentage
  total           Float    @default(0)
  paidAmount      Float    @default(0)
  remaining       Float    @default(0)
  status          String   @default("draft") // draft, sent, partially_paid, paid, overdue, cancelled
  deletedAt       DateTime? // Soft delete
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id])
  project         Project  @relation(fields: [projectId], references: [id])
  items           InvoiceItem[]
}

model InvoiceItem {
  id              String   @id @default(cuid())
  invoiceId       String
  description     String   @default("")
  quantity        Float    @default(1)
  unitPrice       Float    @default(0)
  total           Float    @default(0)
  boqItemId       String?
  createdAt       DateTime @default(now())

  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ==================== PAYMENTS ====================

model Payment {
  id              String   @id @default(cuid())
  voucherNumber   String   @default("")
  projectId       String?
  amount          Float    @default(0)
  payMethod       String   @default("transfer") // cash, cheque, transfer, online
  beneficiary     String   @default("")
  referenceNumber String   @default("")
  status          String   @default("pending") // pending, approved, completed, cancelled
  approvedById    String?
  description     String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  approver        User?    @relation("PaymentApprover", fields: [approvedById], references: [id])
  project         Project? @relation(fields: [projectId], references: [id])
}

// ==================== PROPOSALS ====================

model Proposal {
  id              String   @id @default(cuid())
  number          String   @default("")
  clientId        String
  projectId       String?
  subtotal        Float    @default(0)
  tax             Float    @default(0)
  total           Float    @default(0)
  status          String   @default("draft") // draft, sent, accepted, rejected, expired
  notes           String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client   @relation(fields: [clientId], references: [id])
  project         Project? @relation(fields: [projectId], references: [id])
  items           ProposalItem[]
}

model ProposalItem {
  id              String   @id @default(cuid())
  proposalId      String
  description     String   @default("")
  quantity        Float    @default(1)
  unitPrice       Float    @default(0)
  total           Float    @default(0)
  createdAt       DateTime @default(now())

  proposal        Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
}

// ==================== CONTRACTORS ====================

model Contractor {
  id              String   @id @default(cuid())
  name            String   @default("")
  nameEn          String   @default("")
  companyName     String   @default("")
  companyEn       String   @default("")
  contactPerson   String   @default("")
  phone           String   @default("")
  email           String   @default("")
  address         String   @default("")
  crNumber        String   @default("") // Commercial Registration
  licenseNumber   String   @default("")
  licenseExpiry   DateTime?
  classification      String?   @default("")  // Contractor classification level (e.g., "الدرجة الثالثة")
  establishmentDate   DateTime?              // Company establishment date
  workerCount         Int?      @default(0)  // Number of workers
  engineerCount       Int?      @default(0)  // Number of engineers
  tradeLicense        String?   @default("")  // Trade license number
  tradeLicenseExpiry  DateTime?              // Trade license expiry date
  vatNumber           String?   @default("")  // VAT registration number
  category        String   @default("") // civil, electrical, mep, finishing, plumbing, hvac
   rating          Int      @default(0) // 1-5 stars
  specialties     String   @default("") // comma-separated specialties
  experience      String   @default("") // years of experience description
  bankName        String   @default("")
  bankAccount     String   @default("")
  iban            String   @default("")
  isActive        Boolean  @default(true)
  notes           String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  projects        Project[] @relation("ProjectContractor")
  bids            Bid[]
  evaluations    ContractorEvaluation[]
}

// ==================== CONTRACTOR EVALUATION ====================

model ContractorEvaluation {
  id              String   @id @default(cuid())
  contractorId   String
  projectId       String
  criteria        String   @default("") // experience, financial, technical, past_performance, resources
  score           Int      @default(0) // 0-100
  maxScore        Int      @default(100)
  weight          Float    @default(1) // percentage weight for this criteria
  notes           String   @default("")
  evaluatedBy     String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contractor      Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  bid             Bid?      @relation(fields: [bidId], references: [id])
  bidId           String?
}

// ==================== BIDS ====================

model Bid {
  id                String   @id @default(cuid())
  projectId         String
  contractorId      String?
  contractorName    String   @default("")
  contractorContact String   @default("")
  amount            Float    @default(0)
  technicalScore    Int      @default(0)
  financialScore    Int      @default(0)
  totalScore        Float    @default(0)
  status            String   @default("submitted") // submitted, under_review, accepted, rejected
  deadline          DateTime?
  notes             String   @default("")
  evaluationNotes   String   @default("")
  quoteFile          String   @default("")
  quoteUploadedAt    DateTime?
  rfqSentAt          DateTime?
  rfqStatus          String   @default("pending") // pending, sent, received, reviewing, awarded, rejected
  aiAnalysis         String   @default("")
  contractFile       String   @default("")
  contractSignedAt   DateTime?
  isAwarded          Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project           Project    @relation(fields: [projectId], references: [id])
  contractor        Contractor? @relation(fields: [contractorId], references: [id])
  evaluations       ContractorEvaluation[]
}

// ==================== BUDGETS ====================

model Budget {
  id              String   @id @default(cuid())
  projectId       String
  parentId        String?
  name            String   @default("")
  category        String   @default("") // overall, architectural, structural, electrical, mep
  planned         Float    @default(0)
  actual          Float    @default(0)
  committed       Float    @default(0)
  remaining       Float    @default(0)
  deviation       Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project         Project  @relation(fields: [projectId], references: [id])
  parent          Budget?  @relation("BudgetHierarchy", fields: [parentId], references: [id])
  children        Budget[] @relation("BudgetHierarchy")
}

// ==================== SITE MANAGEMENT ====================

model SiteVisit {
  id              String   @id @default(cuid())
  projectId       String
  date            DateTime
  plotNumber      String   @default("")
  municipality    String   @default("") // ras_al_khaimah, dubai, abu_dhabi, sharjah, ajman, umm_al_quwain, fujairah
  gateDescription String   @default("")
  neighborDesc    String   @default("")
  buildingDesc    String   @default("")
  photos          String   @default("") // JSON array of photo URLs
  status          String   @default("draft") // draft, submitted, approved
  notes           String   @default("")
  createdAt       DateTime @default(now())

  project         Project  @relation(fields: [projectId], references: [id])
}

model Defect {
  id              String   @id @default(cuid())
  projectId       String
  title           String   @default("")
  severity        String   @default("normal") // normal, medium, high, critical
  location        String   @default("")
  photos          String   @default("")
  assigneeId      String?
  resolutionNotes String   @default("")
  status          String   @default("open") // open, in_progress, resolved
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project         Project  @relation(fields: [projectId], references: [id])
